generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Users (Steam Auth) ─────────────────────────────────

model User {
  id          String   @id @default(cuid())
  steamId     String   @unique
  displayName String
  avatarUrl   String?
  profileUrl  String?
  role        Role     @default(USER)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // CS2 stats (fetched from Steam API on login)
  ownsCs2          Boolean?
  cs2PlaytimeHours Int?
  cs2Kills         Int?
  cs2Deaths        Int?
  cs2Wins          Int?
  cs2HeadshotPct   Float?      // 0-100, pre-calculated
  profileVisibility Int?       // 1=private, 3=public
  statsUpdatedAt   DateTime?

  // FACEIT stats
  faceitLevel      Int?        // 1-10
  faceitElo        Int?

  // Profile
  bio          String?  @db.VarChar(500)
  karma        Int      @default(0)
  customName   String?  @db.VarChar(32)
  hidePlaytime Boolean  @default(false)
  hideFaceit   Boolean  @default(false)

  // Ban status
  isBanned     Boolean   @default(false)
  bannedAt     DateTime?
  bannedReason String?

  petitionSignature PetitionSignature?
  opinions          Opinion[]     @relation("UserOpinions")
  opinionVotes      OpinionVote[] @relation("UserOpinionVotes")
  comments          Comment[]     @relation("UserComments")
  commentVotes      CommentVote[] @relation("UserCommentVotes")
  media             Media[]       @relation("UserMedia")
  mediaVotes        MediaVote[]   @relation("UserMediaVotes")

  @@index([steamId])
}

enum Role {
  USER
  MODERATOR
  ADMIN
}

// ── Petition ────────────────────────────────────────────

model PetitionSignature {
  id        String   @id @default(cuid())
  userId    String   @unique
  message   String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
}

// ── Articles / Blog ──────────────────────────────────────

model Article {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  excerpt     String?
  content     String
  coverImage  String?
  published   Boolean   @default(false)
  featured    Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  tags        Tag[]     @relation("ArticleTags")

  @@index([published, publishedAt])
  @@index([featured, published])
}

model Tag {
  id       String    @id @default(cuid())
  name     String    @unique
  slug     String    @unique
  articles Article[] @relation("ArticleTags")
}

// ── Opinions & Suggestions ──────────────────────────────

model Opinion {
  id        String        @id @default(cuid())
  title     String
  content   String
  imageUrl  String?
  authorId  String
  status    ContentStatus @default(APPROVED)
  score     Int           @default(0)
  tags      String[]      @default([])
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  editedAt  DateTime?

  author   User          @relation("UserOpinions", fields: [authorId], references: [id], onDelete: Cascade)
  votes    OpinionVote[]
  comments Comment[]

  @@index([status, score])
  @@index([status, createdAt])
}

model OpinionVote {
  id        String @id @default(cuid())
  opinionId String
  userId    String
  value     Int

  opinion Opinion @relation(fields: [opinionId], references: [id], onDelete: Cascade)
  user    User    @relation("UserOpinionVotes", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([opinionId, userId])
}

model Comment {
  id          String   @id @default(cuid())
  content     String
  authorId    String
  opinionId   String?
  mediaId     String?
  parentId    String?
  isAnonymous Boolean  @default(false)
  score       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author  User      @relation("UserComments", fields: [authorId], references: [id], onDelete: Cascade)
  opinion Opinion?  @relation(fields: [opinionId], references: [id], onDelete: Cascade)
  media   Media?    @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  parent  Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies Comment[] @relation("CommentReplies")
  votes   CommentVote[]

  @@index([opinionId, createdAt])
  @@index([mediaId, createdAt])
  @@index([parentId])
}

model CommentVote {
  id        String @id @default(cuid())
  commentId String
  userId    String
  value     Int

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User    @relation("UserCommentVotes", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
}

enum ContentStatus {
  PENDING
  APPROVED
  REJECTED
  HIDDEN
}

// ── Media ─────────────────────────────────────────────

model Media {
  id           String        @id @default(cuid())
  title        String
  description  String?
  url          String
  platform     MediaPlatform
  embedUrl     String?
  thumbnailUrl String?
  authorId     String
  status       ContentStatus @default(APPROVED)
  score        Int           @default(0)
  tags         String[]      @default([])
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  author   User        @relation("UserMedia", fields: [authorId], references: [id], onDelete: Cascade)
  votes    MediaVote[]
  comments Comment[]

  @@index([status, score])
  @@index([status, createdAt])
}

model MediaVote {
  id      String @id @default(cuid())
  mediaId String
  userId  String
  value   Int

  media Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  user  User  @relation("UserMediaVotes", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([mediaId, userId])
}

enum MediaPlatform {
  YOUTUBE
  INSTAGRAM
  TWITTER
  TIKTOK
  TWITCH
  FACEBOOK
  OTHER
}

// ── Tracked Players (GC Bot + Ban Checking) ────────────

model TrackedPlayer {
  id              String    @id @default(cuid())
  steamId         String    @unique
  displayName     String?
  avatarUrl       String?

  // Premier / Competitive rank (from GC bot)
  premierRating   Int?
  competitiveRank Int?
  wins            Int?

  // Ban status (from Steam API GetPlayerBans)
  vacBanned         Boolean   @default(false)
  numberOfVacBans   Int       @default(0)
  daysSinceLastBan  Int?
  numberOfGameBans  Int       @default(0)
  communityBanned   Boolean   @default(false)

  source            String    @default("manual") // manual, signer, leaderboard
  flagged           Boolean   @default(false)    // fishy stats detected

  profileCheckedAt  DateTime?
  banCheckedAt      DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([premierRating])
  @@index([vacBanned])
  @@index([steamId])
  @@index([source])
  @@index([flagged])
}

// ── Bot Commands (webapp → bot communication) ───────────

model BotCommand {
  id        String   @id @default(cuid())
  command   String
  payload   Json?
  status    String   @default("pending")
  result    Json?
  createdAt DateTime @default(now())

  @@index([status])
  @@index([createdAt])
}

// ── Ban Tracking ────────────────────────────────────────

model BanWave {
  id            String   @id @default(cuid())
  date          DateTime
  title         String
  description   String?
  estimatedBans Int?
  source        String?
  createdAt     DateTime @default(now())

  @@index([date])
}

model BanSnapshot {
  id              String   @id @default(cuid())
  date            DateTime @unique
  totalTracked    Int
  totalVacBanned  Int
  totalGameBanned Int
  newBansToday    Int      @default(0)
  createdAt       DateTime @default(now())

  @@index([date])
}

// ── Outreach Tracker ──────────────────────────────────

model OutreachContact {
  id              String   @id @default(cuid())
  name            String
  role            String   @default("Other")
  email           String?
  socialUrl       String?
  websiteUrl      String?
  avatarUrl       String?
  emailBody       String?
  emailSent       Boolean  @default(false)
  sentAt          DateTime?
  replied         Boolean  @default(false)
  repliedAt       DateTime?
  engaged         Boolean  @default(false)
  notes           String?
  addToSupporters Boolean  @default(false)
  addToNotable    Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([role])
  @@index([emailSent])
  @@index([engaged])
}

// ── Ko-fi Supporters ──────────────────────────────────

model Supporter {
  id            String   @id @default(cuid())
  discordId     String   @unique
  steamId       String
  displayName   String
  avatarUrl     String?
  tier          String
  tierLevel     Int
  customMessage String?  @db.VarChar(200)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isActive, tierLevel])
}

// ── Ko-fi Transactions ────────────────────────────────

model KofiTransaction {
  id                String   @id @default(cuid())
  messageId         String   @unique
  type              String
  amount            Float
  currency          String
  fromName          String
  email             String?
  tierName          String?
  isFirstPayment    Boolean  @default(false)
  isSubscription    Boolean  @default(false)
  isPublic          Boolean  @default(true)
  message           String?
  kofiTransactionId String?
  createdAt         DateTime @default(now())

  @@index([type])
  @@index([createdAt])
}

// ── Site Configuration ──────────────────────────────────

model SiteConfig {
  key   String @id
  value Json
}

// ── Visitor Analytics ──────────────────────────────────

model PageView {
  id        String   @id @default(cuid())
  path      String
  ipHash    String
  country   String?
  city      String?
  userAgent String?
  device    String?
  browser   String?
  os        String?
  referrer  String?
  userId    String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([path])
  @@index([country])
  @@index([ipHash, createdAt])
}
